{
    "paths": {
        "model_dir": "C:\\path\\to\\your\\models",
        "llama_server": "llama-server.exe"
    },
    "services": {
        "embedding": {
            "model_file": "your-embedding-model.gguf",
            "host": "0.0.0.0",
            "port": 8088,
            "threads": 8,
            "extra_args": ["--embedding"]
        },
        "rerank": {
            "model_file": "your-reranker-model.gguf",
            "host": "0.0.0.0",
            "port": 8000,
            "threads": 8,
            "extra_args": ["--embedding", "--pooling", "rank", "--reranking"]
        }
    },
    "docker": {
        "ragflow_dir": "C:\\path\\to\\ragflow\\docker",
        "nginx_pm_dir": "C:\\path\\to\\nginx-proxy-manager"
    },
    "ollama": {
        "api_url": "http://127.0.0.1:11434"
    }
}
